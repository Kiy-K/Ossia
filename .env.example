# =============================================================================
# Ossia — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Then start the server:
#   docker compose up --build
#   # or raw:
#   uvicorn core.api:app --host 0.0.0.0 --port 8000

# ──────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────
OSSIA_API_KEY=change-me-to-a-random-secret

# ──────────────────────────────────────────────
# Model provider — pick one and set its key
# ──────────────────────────────────────────────
PROVIDER=openrouter
MODEL=openai/gpt-4o-mini

# OpenRouter (recommended — access to many models via one API)
OPENROUTER_API_KEY=

# OR OpenAI
# OPENAI_API_KEY=
# PROVIDER=openai
# MODEL=gpt-4o

# OR Anthropic
# ANTHROPIC_API_KEY=
# PROVIDER=anthropic
# MODEL=claude-sonnet-4-20250514

# OR Google Gemini
# GOOGLE_API_KEY=
# PROVIDER=google
# MODEL=gemini-2.0-flash

# ──────────────────────────────────────────────
# Web search (optional — falls back to DuckDuckGo if unset)
# ──────────────────────────────────────────────
# TAVILY_API_KEY=

# ──────────────────────────────────────────────
# Web reviewer — browser-use (optional)
# ──────────────────────────────────────────────
# The `web-reviewer` subagent drives a real Chromium via the browser-use
# SDK. Two modes:
#
#   1. Cloud (default): uses browser-use's hosted browser. Needs a
#      BROWSER_USE_API_KEY (free tier exists but the LLM gateway and
#      anti-bot bypass are paid-only). Set the key below.
#
#   2. Local: uses a Chromium you install once locally via
#      ``.venv/bin/python scripts/install_browser.py`` (downloads
#      ~200MB). FREE — no BROWSER_USE_API_KEY needed for the browser
#      itself. You only pay for LLM calls (routed through your main
#      provider, e.g. openrouter). Works against sites the free-tier
#      cloud browser can't reach.
#
# Pick one. Local is recommended for cost + flexibility.
#
# BROWSER_USE_LOCAL=true
# BROWSER_USE_API_KEY=  # only needed when BROWSER_USE_LOCAL=false
# Path to a persistent Chromium profile (cookies survive across runs):
# BROWSER_USE_USER_DATA_DIR=/var/lib/ossia/chromium-profile
# Disable the Chromium sandbox when running inside Docker / as root:
# BROWSER_USE_CHROMIUM_SANDBOX=false

# ──────────────────────────────────────────────
# Tool result cache (langgraph-redis ToolResultCacheMiddleware)
# ──────────────────────────────────────────────
# Caches exact-match tool results in Redis (when REDIS_URL is set).
# Side-effect tools (``send_``, ``delete_``, ``create_``, ``update_``,
# ``remove_``, ``write_``, ``post_``, ``put_``, ``patch_``, ``edit_``)
# are excluded by the library defaults. Disable for ephemeral runs.
# ENABLE_TOOL_CACHE=true   (default)
# TOOL_CACHE_TTL_SECONDS=3600

# ──────────────────────────────────────────────
# Vector RAG (memory + KB semantic search via Ollama)
# ──────────────────────────────────────────────
# When REDIS_URL is set, the agent's memory store is configured
# with a RediSearch vector index. Embeddings come from the local
# Ollama server (no API key, no rate limits). Match the model and
# dim to what you've pulled.
# Pull the default: ollama pull embeddinggemma
EMBEDDING_MODEL=embeddinggemma
EMBEDDING_DIM=768
# Disable to run the Redis store as key-value only (no RAG):
# ENABLE_VECTOR_INDEX=false

# ──────────────────────────────────────────────
# Knowledge base — comma-separated URLs for search_knowledge_base (optional)
# ──────────────────────────────────────────────
# Each URL is fetched at startup and stored in Redis (when
# REDIS_URL is set) as one searchable document. Title = first H1 in
# the body (or URL stem if none); content = body. Empty = no KB =
# tool falls back to web search.
# Examples:
#   KB_SOURCE_URLS=https://docs.example.com/guide.md,https://docs.example.com/troubleshooting.md
#   KB_SOURCE_URLS=https://internal.example.com/kb/manifest.json   (manifest format: {"docs": [{"url":..., "content":...}, ...]})
KB_SOURCE_URLS=

# ──────────────────────────────────────────────
# Postgres — thread persistence & HITL (optional)
# ──────────────────────────────────────────────
# When using docker compose, this defaults to the postgres service below.
# For external Postgres, set the full DSN:
#   POSTGRES_URL=postgresql://user:password@host:5432/ossia
POSTGRES_URL=postgresql://ossia:ossia@localhost:5432/ossia

# ──────────────────────────────────────────────
# Redis — tool-result cache + memory write lock (optional)
# ──────────────────────────────────────────────
# When unset, surface #1 (cache) and surface #4 (seed_memory lock)
# are no-ops and the agent runs exactly as before. Set to enable.
# For managed Redis, set the full URL:
#   REDIS_URL=redis://user:password@host:6379/0
# REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# Agent behavior
# ──────────────────────────────────────────────
ENABLE_HUMAN_REVIEW=false
MAX_REVISION_LOOPS=3
# Maximum total tool calls per agent run before forcing finalization
# TOOL_CALL_LIMIT=25
# Retry middleware: max attempts, base delay (s), and backoff multiplier for external tool calls
# RETRY_MAX_ATTEMPTS=3
# RETRY_INITIAL_INTERVAL=1.0
# RETRY_BACKOFF_FACTOR=2.0
# Code interpreter: QuickJS sandbox timeout (s) and max permit-to-call invocations
# CODE_INTERPRETER_TIMEOUT=5.0
# CODE_INTERPRETER_MAX_PTC_CALLS=32
# Circuit breaker: consecutive failures before opening, and recovery timeout in seconds
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30.0
# Model retry: max attempts, base delay (s), and backoff multiplier for transient LLM failures
# MODEL_RETRY_MAX_ATTEMPTS=2
# MODEL_RETRY_INITIAL_INTERVAL=0.5
# MODEL_RETRY_BACKOFF_FACTOR=2.0
# Model fallback: secondary model when primary provider is degraded (set both)
# FALLBACK_PROVIDER=openai
# FALLBACK_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────
# Logging (optional — defaults to INFO, JSON format)
# ──────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log output format: "json" (default, for Loki/Grafana) or "text" (for local dev)
LOG_FORMAT=json

# ──────────────────────────────────────────────
# LangSmith tracing (optional)
# ──────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ossia

# ──────────────────────────────────────────────
# Plugins (optional)
# Directory scanned for user-installed plugins. Auto-created on
# first run if it doesn't exist. Drop a Python file with a
# top-level `register(api)` function and it gets loaded.
# The `plugins/` dir next to pyproject.toml is also scanned
# for the first shipped plugin. Default: `<repo>/plugins_local/`.
# OSSIA_PLUGINS_DIR=/path/to/your/plugins

# Path to an `ossia.json` (or `ossia.jsonc`) config file. When
# set, the file is loaded instead of the default
# `./ossia.json` / `./ossia.jsonc` lookup. Supports plugin
# enable/disable, custom plugin paths, and per-plugin config
# dicts passed to `register(api, config=...)`.
# OSSIA_CONFIG=/path/to/your/ossia.json

# ──────────────────────────────────────────────
# MCP servers (optional)
# ──────────────────────────────────────────────
MCP_CONFIG_PATH=.mcp.json

# ──────────────────────────────────────────────
# Monitoring & observability (optional — for docker compose)
# ──────────────────────────────────────────────
# Start the monitoring stack:
#   docker compose --profile monitoring up -d
# Grafana: http://localhost:3000 (admin/ossia)
# Prometheus: http://localhost:9090
# Loki: http://localhost:3100

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=ossia

# Prometheus data retention
PROMETHEUS_RETENTION=30d

# Docker log driver (set to "loki" to ship logs to Loki, requires docker plugin install grafana/loki-docker-driver)
# Warning: switching to loki driver will stop containers if Loki is unreachable. Use json-file for dev.
LOG_DRIVER=json-file
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
