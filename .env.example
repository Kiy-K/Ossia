# =============================================================================
# Ossia — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Then start the server:
#   docker compose up --build
#   # or raw:
#   uvicorn core.api:app --host 0.0.0.0 --port 8000

# ──────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────
OSSIA_API_KEY=change-me-to-a-random-secret

# ──────────────────────────────────────────────
# Model provider — pick one and set its key
# ──────────────────────────────────────────────
PROVIDER=openrouter
MODEL=openai/gpt-4o-mini

# OpenRouter (recommended — access to many models via one API)
OPENROUTER_API_KEY=

# OR OpenAI
# OPENAI_API_KEY=
# PROVIDER=openai
# MODEL=gpt-4o

# OR Anthropic
# ANTHROPIC_API_KEY=
# PROVIDER=anthropic
# MODEL=claude-sonnet-4-20250514

# OR Google Gemini
# GOOGLE_API_KEY=
# PROVIDER=google
# MODEL=gemini-2.0-flash

# ──────────────────────────────────────────────
# Web search (optional — falls back to DuckDuckGo if unset)
# ──────────────────────────────────────────────
# TAVILY_API_KEY=

# ──────────────────────────────────────────────
# Postgres — thread persistence & HITL (optional)
# ──────────────────────────────────────────────
# When using docker compose, this defaults to the postgres service below.
# For external Postgres, set the full DSN:
#   POSTGRES_URL=postgresql://user:password@host:5432/ossia
POSTGRES_URL=postgresql://ossia:ossia@localhost:5432/ossia

# ──────────────────────────────────────────────
# Agent behavior
# ──────────────────────────────────────────────
ENABLE_HUMAN_REVIEW=false
MAX_REVISION_LOOPS=3

# ──────────────────────────────────────────────
# LangSmith tracing (optional)
# ──────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ossia

# ──────────────────────────────────────────────
# MCP servers (optional)
# ──────────────────────────────────────────────
MCP_CONFIG_PATH=.mcp.json

# ──────────────────────────────────────────────
# Monitoring & observability (optional — for docker compose)
# ──────────────────────────────────────────────
# Start the monitoring stack:
#   docker compose --profile monitoring up -d
# Grafana: http://localhost:3000 (admin/ossia)
# Prometheus: http://localhost:9090
# Loki: http://localhost:3100

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=ossia

# Prometheus data retention
PROMETHEUS_RETENTION=30d

# Docker log driver (set to "loki" to ship logs to Loki, requires docker plugin install grafana/loki-docker-driver)
# Warning: switching to loki driver will stop containers if Loki is unreachable. Use json-file for dev.
LOG_DRIVER=json-file
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3
