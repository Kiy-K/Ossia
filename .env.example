# Model provider and model ID (no hardcoded vendor)
PROVIDER=openrouter
MODEL=openai/gpt-4o-mini

# API keys (only fill the one matching your PROVIDER)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
NEBIUS_API_KEY=
FIREWORKS_API_KEY=
BASETEN_API_KEY=

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ossia

# Postgres persistence (required for checkpointing in production)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/ossia

# API authentication (required for the FastAPI server)
OSSIA_API_KEY=

# Agent behavior
ENABLE_HUMAN_REVIEW=true
MAX_REVISION_LOOPS=3

# MCP configuration path
MCP_CONFIG_PATH=.mcp.json
