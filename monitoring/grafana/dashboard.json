{
  "__inputs": [],
  "__requires": [],
  "title": "Ossia Agent Dashboard",
  "description": "Metrics, logs, and performance for the Ossia AI agent server.",
  "schemaVersion": 39,
  "version": 1,
  "uid": "ossia-agent",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "tags": ["ossia", "agent", "llm"],
  "panels": [
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "rate(http_requests_total{job='ossia'}[5m])",
          "legendFormat": "requests/s"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "rate(http_requests_total{job='ossia',status=~'5..'}[5m]) / rate(http_requests_total{job='ossia'}[5m]) * 100",
          "legendFormat": "error %"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "P99 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job='ossia'}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(http_requests_active_total{job='ossia'})",
          "legendFormat": "active"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job='ossia'}",
          "legendFormat": "uptime"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "decimals": 1
        }
      }
    },
    {
      "title": "HTTP Requests by Status Code (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 6,
      "targets": [
        {
          "expr": "rate(http_requests_total{job='ossia',status=~'2..'}[5m])",
          "legendFormat": "2xx"
        },
        {
          "expr": "rate(http_requests_total{job='ossia',status=~'4..'}[5m])",
          "legendFormat": "4xx"
        },
        {
          "expr": "rate(http_requests_total{job='ossia',status=~'5..'}[5m])",
          "legendFormat": "5xx"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["max", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 7,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job='ossia'}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job='ossia'}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job='ossia'}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["max", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "Recent Logs — Errors & Warnings",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "id": 8,
      "targets": [
        {
          "expr": "{job=~\".+\"} |=~ \"error|warning|exception|traceback|failed\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogs": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      }
    },
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "id": 9,
      "targets": [
        {
          "expr": "rate({job=\"ossia\"}[5m])",
          "legendFormat": "ossia"
        },
        {
          "expr": "rate({job=\"caddy\"}[5m])",
          "legendFormat": "caddy"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["max", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": {
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "showPoints": "never"
          }
        }
      },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      }
    },
    {
      "title": "Memory Usage (process_resident_memory_bytes)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 22 },
      "id": 10,
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job='ossia'}",
          "legendFormat": "RSS"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500000000 },
              { "color": "red", "value": 1000000000 }
            ]
          }
        }
      }
    },
    {
      "title": "CPU Usage (process_cpu_seconds_total)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 22 },
      "id": 11,
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job='ossia'}[5m])",
          "legendFormat": "cpu"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["max", "mean"],
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "showPoints": "never"
          },
          "max": 100
        }
      }
    },
    {
      "title": "Circuit Breaker: Opens & Blocks",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 28 },
      "id": 12,
      "targets": [
        {
          "expr": "rate(circuit_breaker_opens_total{job='ossia'}[5m])",
          "legendFormat": "opens ({{tool}})"
        },
        {
          "expr": "rate(circuit_breaker_blocks_total{job='ossia'}[5m])",
          "legendFormat": "blocks ({{tool}})"
        }
      ],
      "options": {
        "legend": {
          "calcs": ["max", "mean"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "title": "Circuit Breaker: Probe Success Rate",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 28 },
      "id": 13,
      "targets": [
        {
          "expr": "rate(circuit_breaker_probe_successes_total[5m]) / (rate(circuit_breaker_probes_total[5m]) + 1) * 100",
          "legendFormat": "probe success %"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 95 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    }
  ]
}
